# Copy to .env and fill in. compose.yaml reads from .env automatically.

# --- Required: Birdfy/Netvue account credentials ---
BIRDFY_EMAIL=you@example.com
BIRDFY_PASSWORD=your-password

# --- Required: which camera to stream ---
# Serial number from the Birdfy app, or run the bridge once with any value
# to see the available device serials in the logs.
DEVICE_ID=1234567890123456

# --- Optional: where to publish RTSP ---
# The container bundles MediaMTX on port 8554. By default the bridge publishes
# to the in-container MediaMTX at rtsp://localhost:8554/birdfy, which is then
# exposed on the host. Override either piece if you want a different path or
# want to publish to an external RTSP server (e.g. Frigate's go2rtc).
#
# RTSP_HOST=localhost:8554
# RTSP_PATH=birdfy
#
# Or set the full URL directly (overrides RTSP_HOST / RTSP_PATH):
# RTSP_OUTPUT=rtsp://frigate:8554/birdfy

# --- Optional: logging ---
# LOG_LEVEL=INFO       # DEBUG / INFO / WARNING / ERROR
# LOG_FILE=            # empty = stdout only (compose.yaml sets this by default)
# NOISY_LOG_LEVEL=WARNING  # floor for chatty aiortc/aioice/websockets loggers.
#                          # They log every RTP packet at DEBUG (~99% of log
#                          # volume). Set to DEBUG only for deep packet-trace
#                          # debugging.

# --- Optional: auth token persistence ---
# The bridge caches its login token + device UDID under BIRDFY_STATE_DIR and
# reuses the token on restart, so it doesn't do a fresh login every time (a fresh
# login is what triggers Netvue's "new device logged in" email). compose.yaml
# sets this to /data backed by a named volume; only override if not using compose.
# BIRDFY_STATE_DIR=/data
#
# Set to disable token caching entirely (always do a fresh login):
# NVS_NO_TOKEN_CACHE=1
